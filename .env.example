# Anthropic API key for LLM chat
ANTHROPIC_API_KEY=sk-ant-...

# LLM model to use
LLM_MODEL=claude-sonnet-4-20250514

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string

# Public URL of your deployment (required in production)
BASE_URL=https://sinter-3d.com

# Edition: "community" or "paid"
VITE_EDITION=community

# Lemon Squeezy (paid edition only — create products in LS dashboard)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_100=
LEMONSQUEEZY_VARIANT_500=
LEMONSQUEEZY_VARIANT_1000=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Site-wide password gate (optional).
# Visit /gate to unlock via Basic Auth. Leave empty to disable.
SITE_PASSWORD=

# Allowlist: comma-separated emails that can use the app.
# Leave empty to allow all authenticated users.
ALLOWED_EMAILS=

# Data directory for SQLite DB and project files
DATA_DIR=./data

# Storage limit per user in MB (0 = unlimited, requires credit allocation)
STORAGE_LIMIT_MB=0
