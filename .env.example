# Anthropic API key for LLM chat
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session secret (generate a random string)
SESSION_SECRET=change-me-to-a-random-string

# Public URL of your deployment
BASE_URL=https://sinter-3d.com

# LLM model to use
LLM_MODEL=claude-sonnet-4-20250514

# Stripe (paid edition only)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Edition: "community" or "paid"
VITE_EDITION=paid

# Site-wide password gate. Set to password-protect the entire site.
# Users see a browser login prompt. Username can be anything, password must match.
# Leave empty to disable (site is public).
SITE_PASSWORD=

# Allowlist: comma-separated emails that can use the app.
# Leave empty to allow all authenticated users.
ALLOWED_EMAILS=

# Data directory for SQLite and files
DATA_DIR=./data
